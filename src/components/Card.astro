---
import { Icon } from 'astro-icon/components';
import { toIconName } from '../lib/data';

interface Props {
  title?: string;
  icon?: string;
  class?: string;
  href?: string;
  variant?: 'default' | 'dark';
}

const { title, icon, class: className, href, variant = 'default' } = Astro.props;

const iconName = icon ? toIconName(icon) : null;

const cardClass = variant === 'dark' ? 'card-dark' : 'card';
---

<div class={`${cardClass} p-m ${className || ''}`}>
  {title && (
    <h3 class="flex items-center gap-2xs">
      {iconName && <Icon name={iconName} class="w-6 h-6 text-primary" aria-hidden="true" />}
      {title}
    </h3>
  )}
  <slot />
  {href && (
    <a href={href} class="inline-flex items-center gap-2xs text-primary text-text-s mt-m hover:text-secondary transition-colors duration-300 no-underline">
      En savoir plus
      <Icon name="ph:arrow-right" class="w-4 h-4" aria-hidden="true" />
    </a>
  )}
</div>
