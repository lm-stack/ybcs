---
interface Props {
  cols: '1' | '2' | '3' | '4' | '1-2' | '2-1' | '1-3' | '3-1';
  gap?: string;
  class?: string;
}

const { cols, gap = 'l', class: className } = Astro.props;

const colsMap: Record<string, string> = {
  '1': 'grid grid-cols-1',
  '2': 'grid grid-cols-1 md:grid-cols-2',
  '3': 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  '4': 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
  '2-1': 'grid grid-cols-1 md:grid-cols-[2fr_1fr]',
  '1-2': 'grid grid-cols-1 md:grid-cols-[1fr_2fr]',
  '1-3': 'grid grid-cols-1 md:grid-cols-[1fr_3fr]',
  '3-1': 'grid grid-cols-1 md:grid-cols-[3fr_1fr]',
};

const gapMap: Record<string, string> = {
  '3xs': 'gap-3xs',
  '2xs': 'gap-2xs',
  'xs': 'gap-xs',
  's': 'gap-s',
  'm': 'gap-m',
  'l': 'gap-l',
  'xl': 'gap-xl',
  '2xl': 'gap-2xl',
  '3xl': 'gap-3xl',
  '4xl': 'gap-4xl',
};

const gridClasses = [
  colsMap[cols],
  gapMap[gap] || gapMap['l'],
  className || '',
].filter(Boolean).join(' ');
---

<div class={gridClasses}>
  <slot />
</div>
