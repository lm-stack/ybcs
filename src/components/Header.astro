---
import { Icon } from 'astro-icon/components';
import Button from './Button.astro';
import type { SiteData } from '../lib/data';

interface Props {
  site: SiteData;
  currentUrl: string;
  isDark?: boolean;
}

const { site, currentUrl, isDark = false } = Astro.props;

// Separate Contact from regular nav items (it becomes a CTA button)
const navItems = site.nav.filter((item) => item.url !== '/contact/');
const contactItem = site.nav.find((item) => item.url === '/contact/');

const headerClass = isDark
  ? 'fixed top-0 left-0 right-0 z-100 bg-transparent transition-all duration-300'
  : 'fixed top-0 left-0 right-0 z-100 bg-white/95 backdrop-blur-sm shadow-card transition-all duration-300';

const logoClass = isDark
  ? 'font-bold text-h4 font-secondary no-underline text-white hover:text-white'
  : 'font-bold text-h4 font-secondary no-underline text-secondary hover:text-secondary';

const linkClass = isDark
  ? 'text-text-s transition-colors duration-300 no-underline text-white/80 hover:text-white'
  : 'text-text-s transition-colors duration-300 no-underline text-text hover:text-secondary';

const dropdownTriggerClass = isDark
  ? 'bg-transparent border-none cursor-pointer inline-flex items-center gap-3xs p-0 font-inherit text-text-s transition-colors duration-300 text-white/80 hover:text-white'
  : 'bg-transparent border-none cursor-pointer inline-flex items-center gap-3xs p-0 font-inherit text-text-s transition-colors duration-300 text-text hover:text-secondary';

const dropdownMenuClass = isDark
  ? 'hidden absolute top-full left-1/2 -translate-x-1/2 min-w-[200px] bg-secondary/95 backdrop-blur-md shadow-deep rounded py-2xs mt-xs z-[101] border border-white/10'
  : 'hidden absolute top-full left-1/2 -translate-x-1/2 min-w-[200px] bg-white shadow-card rounded py-2xs mt-xs z-[101] border border-border';

const dropdownLinkClass = isDark
  ? 'block py-2xs px-s text-text-s whitespace-nowrap text-white/70 hover:text-white hover:bg-white/5 transition-colors duration-200'
  : 'block py-2xs px-s text-text-s whitespace-nowrap text-text hover:text-primary hover:bg-bg-light transition-colors duration-200';

const burgerBarClass = isDark
  ? 'block w-6 h-0.5 bg-white'
  : 'block w-6 h-0.5 bg-secondary';

const searchIconClass = isDark
  ? 'text-white/80 hover:text-white transition-colors duration-300'
  : 'text-text hover:text-primary transition-colors duration-300';
---

<header
  id="header"
  class={headerClass}
  role="banner"
  data-pagefind-ignore
  data-dark={isDark ? 'true' : undefined}
>
  <div class="flex items-center justify-between max-w-container mx-auto py-s px-m">
    {/* Logo */}
    <a
      href="/"
      class={logoClass}
      aria-label={`Accueil — ${site.name}`}
    >
      {site.logoText}
    </a>

    {/* Desktop nav */}
    <nav class="hidden md:flex items-center gap-l" aria-label="Navigation principale">
      {navItems.map((item) => {
        if (item.children && item.children.length > 0) {
          return (
            <div class="header__dropdown relative">
              <button
                class={dropdownTriggerClass}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <Icon name="ph:caret-down" class="w-4 h-4" aria-hidden="true" />
              </button>
              <div class={`header__dropdown-menu ${dropdownMenuClass}`}>
                {item.children.map((child) => (
                  <a
                    href={child.url}
                    class:list={[
                      dropdownLinkClass,
                      { 'text-primary font-semibold': currentUrl === child.url },
                    ]}
                    {...(currentUrl === child.url ? { 'aria-current': 'page' } : {})}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          );
        }

        return (
          <a
            href={item.url}
            class:list={[
              linkClass,
              { 'text-primary font-semibold': currentUrl === item.url },
            ]}
            {...(currentUrl === item.url ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
        );
      })}

      {site.searchUrl && (
        <a
          href={site.searchUrl}
          class={searchIconClass}
          aria-label="Recherche"
        >
          <Icon name="ph:magnifying-glass" class="w-5 h-5" aria-hidden="true" />
        </a>
      )}

      {contactItem && (
        <Button href={contactItem.url} variant="primary">
          {contactItem.label}
        </Button>
      )}
    </nav>

    {/* Burger button */}
    <button
      id="burger"
      class="flex md:hidden flex-col gap-[6px] bg-transparent border-none cursor-pointer p-0"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Ouvrir le menu"
    >
      <span class={burgerBarClass}></span>
      <span class={burgerBarClass}></span>
      <span class={burgerBarClass}></span>
    </button>
  </div>
</header>
