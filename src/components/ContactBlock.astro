---
import { Icon } from 'astro-icon/components';
import Button from './Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  email: string;
  phone?: string;
  addresses?: string[];
  showPromise?: boolean;
}

const {
  title = 'Vous avez une question ?',
  subtitle = 'Notre équipe se tient à votre disposition',
  email,
  phone,
  addresses = [],
  showPromise = true,
} = Astro.props;
---

<section class="section-dark relative py-4xl overflow-hidden">
  <div class="halo halo--blue w-[400px] h-[400px] -top-[100px] right-[10%]" aria-hidden="true"></div>

  <div class="relative z-10 max-w-container mx-auto px-m text-center">
    <h2 class="text-white mb-xs">{title}</h2>
    <p class="text-[#BAC4D6] text-text-xl mb-xl">{subtitle}</p>

    <Button href="/contact/" variant="primary" icon="arrow-right">
      Contactez-nous
    </Button>

    {showPromise && (
      <p class="text-primary text-text-s mt-m">
        <Icon name="ph:clock" class="inline w-4 h-4 mr-2xs" aria-hidden="true" />
        Réponse en 24 heures seulement
      </p>
    )}

    <div class="flex flex-col md:flex-row justify-center gap-m mt-2xl">
      <a href={`mailto:${email}`} class="tag-highlight text-white text-text-s no-underline hover:bg-white/10 transition-all duration-300">
        <Icon name="ph:envelope-simple" class="w-4 h-4" aria-hidden="true" />
        {email}
      </a>
      {phone && (
        <a href={`tel:${phone.replace(/\s/g, '')}`} class="tag-highlight text-white text-text-s no-underline hover:bg-white/10 transition-all duration-300">
          <Icon name="ph:phone" class="w-4 h-4" aria-hidden="true" />
          {phone}
        </a>
      )}
    </div>

    {addresses.length > 0 && (
      <div class="flex flex-col md:flex-row justify-center gap-m mt-m">
        {addresses.map((addr) => (
          <span class="tag-highlight text-white/80 text-text-s">
            <Icon name="ph:map-pin" class="w-4 h-4 shrink-0" aria-hidden="true" />
            {addr}
          </span>
        ))}
      </div>
    )}
  </div>
</section>
