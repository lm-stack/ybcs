---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getEntry } from 'astro:content';
import { getSiteData, type HomePageData } from '../lib/data';

interface Props {
  seo: {
    title: string;
    description: string;
    ogImage?: string;
  };
  breadcrumb?: string;
  isHome?: boolean;
  noindex?: boolean;
  headerDark?: boolean;
}

const site = await getSiteData();
const { seo, breadcrumb, isHome = false, noindex = false, headerDark = false } = Astro.props;
const currentUrl = Astro.url.pathname;
const homeData = await getEntry('pages', 'home');
const footerDescription = (homeData?.data as HomePageData)?.footer?.description || '';
---

<!DOCTYPE html>
<html lang={site.lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' data: https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' data: https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https:; frame-src https://challenges.cloudflare.com;">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <title>{seo.title} | {site.name}</title>
  <meta name="description" content={seo.description}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <link rel="canonical" href={`${site.url}${currentUrl}`}>

  <!-- Open Graph -->
  <meta property="og:title" content={`${seo.title} | ${site.name}`}>
  <meta property="og:description" content={seo.description}>
  <meta property="og:image" content={`${site.url}${seo.ogImage || site.ogImage}`}>
  <meta property="og:url" content={`${site.url}${currentUrl}`}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content={site.name}>
  <meta property="og:locale" content="fr_CH">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${seo.title} | ${site.name}`}>
  <meta name="twitter:description" content={seo.description}>
  <meta name="twitter:image" content={`${site.url}${seo.ogImage || site.ogImage}`}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin>

  <!-- Preload fonts -->
  {site.fontsPreload && site.fontsPreload.map((font: string) => (
    <link rel="preload" href={font} as="font" type="font/woff2" crossorigin>
  ))}
  <ViewTransitions />
</head>
<body class="text-text font-primary antialiased">

  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[200] focus:bg-primary focus:text-white focus:py-xs focus:px-s focus:rounded focus:text-text-s">
    Aller au contenu principal
  </a>

  <Header site={site} currentUrl={currentUrl} isDark={headerDark} />
  <MobileMenu site={site} />

  <main id="main-content" data-pagefind-body>
    {breadcrumb && <Breadcrumb breadcrumb={breadcrumb} />}
    <slot />
  </main>

  <Footer site={site} />

  <JsonLd site={site} breadcrumb={breadcrumb} currentUrl={currentUrl} isHome={isHome} />

  <script src="../scripts/main.ts"></script>
</body>
</html>
