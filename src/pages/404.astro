---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
---

<Base
  seo={{ title: 'Page introuvable', description: "La page que vous recherchez n'existe pas ou a été déplacée." }}
  noindex
>
  <div data-pagefind-ignore="all">
    <section class="py-4xl">
      <div class="max-w-container mx-auto px-m text-center">
        <p class="text-h1 mb-m">404</p>
        <h1 class="mb-s">Page introuvable</h1>
        <p class="text-text-l mb-xl text-text">La page que vous recherchez n'existe pas ou a été déplacée.</p>
        <Button href="/" variant="primary" icon="house">Retour à l'accueil</Button>
      </div>
    </section>
  </div>
</Base>
